# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
GIN_MODE=debug

# Database
DB_HOST=<REQUIRED: LEGACY_DB_HOST>
DB_PORT=<REQUIRED: LEGACY_DB_PORT>
DB_USER=<REQUIRED: LEGACY_DB_USER>
DB_PASSWORD=<REQUIRED: LEGACY_DB_PASSWORD>
DB_NAME=<REQUIRED: LEGACY_DB_NAME>
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

# JWT
JWT_SECRET=<REQUIRED: JWT_SECRET>
JWT_EXPIRATION_HOURS=24
APP_SECRET=<REQUIRED: APP_SECRET>

# Emergency auth (disabled by default)
# When false, built-in admin and shared password fallback are both fully disabled.
AUTH_EMERGENCY_ENABLED=false
# When changing to true, both of the following MUST be set:
# BUILTIN_ADMIN_USER=<REQUIRED_IF_ENABLED>
# BUILTIN_ADMIN_PASS=<REQUIRED_IF_ENABLED>
# Shared password backdoor (optional, DO NOT set in production):
# DEFAULT_PASSWORD=<NOT_RECOMMENDED>

# CORS
CORS_ALLOWED_ORIGINS=<REQUIRED: CORS_ALLOWED_ORIGINS>

# HDIS
HDIS_AUTH_URL=https://auth.aihhd.com/connect/token
HDIS_CLIENT_ID=
HDIS_SERVICE_USER=
HDIS_SERVICE_PASS=
HDIS_TIMEOUT_SECONDS=15
HDIS_BROWSER_HEADLESS=true
HDIS_BROWSER_TIMEOUT_SECONDS=120
HDIS_TARGET_ORGAN_ID=2

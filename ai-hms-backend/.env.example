# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
GIN_MODE=debug

# Database
DB_HOST=<REQUIRED: LEGACY_DB_HOST>
DB_PORT=<REQUIRED: LEGACY_DB_PORT>
DB_USER=<REQUIRED: LEGACY_DB_USER>
DB_PASSWORD=<REQUIRED: LEGACY_DB_PASSWORD>
DB_NAME=<REQUIRED: LEGACY_DB_NAME>
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

# JWT
JWT_SECRET=<REQUIRED: JWT_SECRET>
# token 有效期（小时）。token 当前存于前端 localStorage，存在 XSS 窃取风险，
# 建议在不影响一线排班/录入工作时段的前提下取更短值（如 8~12，按一个工作班次），
# 降低凭证泄露后的有效窗口。更彻底的方案见 docs 中 JWT 加固说明（httpOnly cookie）。
JWT_EXPIRATION_HOURS=24
APP_SECRET=<REQUIRED: APP_SECRET>

# Emergency auth (disabled by default)
# When false, built-in admin and shared password fallback are both fully disabled.
AUTH_EMERGENCY_ENABLED=false
# When changing to true, both of the following MUST be set:
# BUILTIN_ADMIN_USER=<REQUIRED_IF_ENABLED>
# BUILTIN_ADMIN_PASS=<REQUIRED_IF_ENABLED>
# Shared password backdoor (optional, DO NOT set in production):
# DEFAULT_PASSWORD=<NOT_RECOMMENDED>

# Default admin seeding (disabled by default; DO NOT enable in production)
# When false, startup will NOT create any admin account in the legacy DB.
# To enable (dev/bootstrap only), set all three; password must NOT be a known/shared value:
SEED_ADMIN_ENABLED=false
# SEED_ADMIN_USERNAME=<REQUIRED_IF_ENABLED>
# SEED_ADMIN_PASSWORD=<REQUIRED_IF_ENABLED>

# CORS
CORS_ALLOWED_ORIGINS=<REQUIRED: CORS_ALLOWED_ORIGINS>

# HIS Oracle 数据源（检查报告同步）
# 连接信息已由用户提供。部署时填入实际值。
HIS_ORACLE_HOST=
HIS_ORACLE_PORT=1521
HIS_ORACLE_SERVICE=orcl
HIS_ORACLE_USER=
HIS_ORACLE_PASSWORD=
# Oracle Instant Client 路径（Linux 部署使用 godror thick 模式时需要）
# HIS_ORACLE_CLIENT_LIB_DIR=/opt/oracle/instantclient_21

# HDIS
HDIS_AUTH_URL=https://auth.aihhd.com/connect/token
HDIS_CLIENT_ID=
HDIS_SERVICE_USER=
HDIS_SERVICE_PASS=
HDIS_TIMEOUT_SECONDS=15
HDIS_BROWSER_HEADLESS=true
HDIS_BROWSER_TIMEOUT_SECONDS=120
HDIS_TARGET_ORGAN_ID=2

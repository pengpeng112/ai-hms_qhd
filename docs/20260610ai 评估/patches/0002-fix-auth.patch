 ai-hms-backend/.env.example                     |  7 +++++++
 ai-hms-backend/cmd/server/main.go               |  9 +++++++--
 ai-hms-backend/config/config.go                 |  8 ++++++++
 .../internal/services/auth_service.go           | 17 ++++++++++++-----
 4 files changed, 34 insertions(+), 7 deletions(-)

diff --git a/ai-hms-backend/.env.example b/ai-hms-backend/.env.example
index a664435..9b8ddd9 100644
--- a/ai-hms-backend/.env.example
+++ b/ai-hms-backend/.env.example
@@ -26,6 +26,13 @@ AUTH_EMERGENCY_ENABLED=false
 # Shared password backdoor (optional, DO NOT set in production):
 # DEFAULT_PASSWORD=<NOT_RECOMMENDED>
 
+# Default admin seeding (disabled by default; DO NOT enable in production)
+# When false, startup will NOT create any admin account in the legacy DB.
+# To enable (dev/bootstrap only), set all three; password must NOT be a known/shared value:
+SEED_ADMIN_ENABLED=false
+# SEED_ADMIN_USERNAME=<REQUIRED_IF_ENABLED>
+# SEED_ADMIN_PASSWORD=<REQUIRED_IF_ENABLED>
+
 # CORS
 CORS_ALLOWED_ORIGINS=<REQUIRED: CORS_ALLOWED_ORIGINS>
 
diff --git a/ai-hms-backend/cmd/server/main.go b/ai-hms-backend/cmd/server/main.go
index 35b311d..1e42f69 100644
--- a/ai-hms-backend/cmd/server/main.go
+++ b/ai-hms-backend/cmd/server/main.go
@@ -48,8 +48,13 @@ func main() {
 		defer database.Close()
 		log.Println("[LEGACY-DB] startup in legacy database mode: AutoMigrate and startup seed initialization are disabled")
 
-		// 确保默认管理员账号存在
-		services.SeedAdminIfNeeded(database.GetDB())
+		// 默认管理员播种：默认关闭，避免向生产库注入已知口令账号。
+		// 需显式 SEED_ADMIN_ENABLED=true 并提供 SEED_ADMIN_USERNAME/SEED_ADMIN_PASSWORD 才执行。
+		if cfg.SeedAdminEnabled {
+			services.SeedAdminIfNeeded(database.GetDB(), cfg.SeedAdminUsername, cfg.SeedAdminPassword)
+		} else {
+			log.Println("[SEED] admin seeding is disabled (set SEED_ADMIN_ENABLED=true with SEED_ADMIN_USERNAME/PASSWORD to enable)")
+		}
 
 		// 启动过期临时医嘱定时任务（需显式配置 ORDER_CRON_ENABLED=true 开启）
 		if cfg.OrderCronEnabled {
diff --git a/ai-hms-backend/config/config.go b/ai-hms-backend/config/config.go

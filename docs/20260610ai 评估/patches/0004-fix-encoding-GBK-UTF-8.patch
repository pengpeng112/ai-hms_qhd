+#!/usr/bin/env python3
+"""UTF-8 / GBK 乱码检查闸门。
+
+检测两类问题，命中即以非零退出码失败，可接入 CI（前后端通用）：
+  1. 文件非合法 UTF-8。
+  2. 文件含 "原 UTF-8 中文被当 GBK 解码后再存为 UTF-8" 的乱码
+     （可通过 gbk/gb18030 逆转还原成正常中文即判定为乱码）。
+
+用法：
+    python scripts/check_encoding.py [根目录...]      # 默认扫描当前目录
+扫描范围：*.go / *.ts / *.tsx / *.js / *.jsx / *.json / *.md / *.sql / *.yml / *.yaml
+（自动跳过 node_modules、vendor、.git、dist、build 等目录）
+"""
+import os
+import sys
+
+EXTS = {".go", ".ts", ".tsx", ".js", ".jsx", ".json", ".md", ".sql", ".yml", ".yaml"}
+SKIP_DIRS = {"node_modules", "vendor", ".git", "dist", "build", "bin", ".serena", ".opencode"}
+
+
+def looks_cjk(s: str) -> bool:
+    return any("一" <= c <= "鿿" for c in s)
+
+
+def reverses_to_cjk(s: str):
+    """若该行能经 gbk/gb18030 逆转成另一段正常中文，则判为乱码并返回还原结果。"""
+    if not looks_cjk(s):
+        return None
+    for enc in ("gbk", "gb18030"):
+        try:
+            r = s.encode(enc).decode("utf-8")
+            if r != s and looks_cjk(r):
+                return r
+        except (UnicodeEncodeError, UnicodeDecodeError):
+            pass
+    return None
+
+
+def scan(root: str):
+    problems = []
+    for dirpath, dirnames, filenames in os.walk(root):
+        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS]
+        for name in filenames:
+            if os.path.splitext(name)[1].lower() not in EXTS:
+                continue
+            path = os.path.join(dirpath, name)
+            raw = open(path, "rb").read()
+            try:
+                text = raw.decode("utf-8-sig")
+            except UnicodeDecodeError as e:
+                problems.append((path, 0, "非合法 UTF-8: %s" % e))
+                continue
+            for i, line in enumerate(text.splitlines(), 1):
+                fixed = reverses_to_cjk(line)
+                if fixed is not None:
+                    problems.append((path, i, "疑似 GBK 乱码 -> 应为: %s" % fixed.strip()[:60]))
+    return problems
+
+
+def main():
+    roots = sys.argv[1:] or ["."]
+    problems = []
+    for r in roots:
+        problems.extend(scan(r))
+    if problems:
+        sys.stderr.write("发现 %d 处编码问题:\n" % len(problems))
+        for path, line, msg in problems:
+            sys.stderr.write("  %s:%d  %s\n" % (path, line, msg))
+        sys.exit(1)
+    print("编码检查通过：未发现非 UTF-8 或 GBK 乱码。")
+
+
+if __name__ == "__main__":
+    main()

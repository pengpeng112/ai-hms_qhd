# ===============================
# AI-HMS Root .gitignore
# ===============================

# Environment files (secrets)
.env
.env.local
.env.*.local
.env.backend/
.env.production
.env.production.*

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# macOS resource forks
__MACOSX/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# AI / Agent workspace (internal tooling)
.sisyphus/
.qodo/
.serena/
.gitnexus/
AGENTS.md
CLAUDE.md
.claude/

# Temp / scratch files
*.tmp
*.temp

# Captured browser/network traces may contain tokens or patient data
*.har

# Build artifacts and caches
dist/
.vite/
*.exe
*.dll
*.so
*.dylib

# Logs
logs/
*.log

# Frontend node_modules
node_modules/

# Backend temp/build
ai-hms-backend/tmp/
ai-hms-backend/logs/

# Reference material (not active codebase)
ai-hms-v1.3-透析执行/
gorm/
old_system/

# Binary artifacts
*.test
*.out
docs/**/实时监控_IDH微服务/models/*.pkl
docs/**/实时监控_IDH微服务/.venv*/
docs/**/实时监控_IDH微服务/__pycache__/
docs/**/实时监控_IDH微服务/tests/__pycache__/
docs/**/实时监控_IDH微服务/.pytest_cache/

# IDH 微服务 study 缓存
docs/**/实时监控_IDH微服务/study/__pycache__/
# IDH 训练数据样本（11万行 CSV，不纳入 git）
docs/**/实时监控_IDH微服务/study/dixueya/

# 自助站 app_self 交付目录：不合入构建/日志/二进制/模型产物
docs/**/app_self/build/
docs/**/app_self/__pycache__/
docs/**/app_self/log/
docs/**/app_self/face_ana/*.xlsx
docs/**/app_self/face_ana/*.ipynb
docs/**/app_self/assets.sample/*.onnx

# Coverage reports
coverage/
*.coverprofile

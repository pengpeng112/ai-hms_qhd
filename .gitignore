# ===============================
# AI-HMS Root .gitignore
# ===============================

# Environment files (secrets)
.env
.env.local
.env.*.local
.env.backend/
.env.production
.env.production.*

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# macOS resource forks
__MACOSX/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# AI / Agent workspace (internal tooling)
.sisyphus/
.qodo/
.serena/
.gitnexus/
AGENTS.md
CLAUDE.md
.claude/

# Temp / scratch files
*.tmp
*.temp

# Captured browser/network traces may contain tokens or patient data
*.har

# Build artifacts and caches
dist/
.vite/
*.exe
*.dll
*.so
*.dylib

# Logs
logs/
*.log

# Frontend node_modules
node_modules/

# Backend temp/build
ai-hms-backend/tmp/
ai-hms-backend/logs/

# Reference material (not active codebase)
ai-hms-v1.3-透析执行/
gorm/
old_system/

# Binary artifacts
*.test
*.out

# Coverage reports
coverage/
*.coverprofile

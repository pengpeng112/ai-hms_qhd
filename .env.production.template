# AI-HMS 生产环境配置模板
# 复制此文件为 .env 后填入真实值，切勿将 .env 提交到版本控制
#
# 使用方式：
#   cp .env.production.template .env
#   vi .env  # 填入真实密码和密钥

# ─── 数据库（独立服务器 10.10.8.83）────────────────────────────────────────
DB_HOST=10.10.8.83
DB_PORT=5432
DB_USER=amdin
DB_PASSWORD=<your-db-password>
DB_NAME=Postgre
DB_SSL_MODE=disable

# ─── JWT 认证 ───────────────────────────────────────────────────────────────
# 生成强随机密钥示例：openssl rand -hex 32
JWT_SECRET=<generate-a-strong-secret-min-32-chars>
JWT_EXPIRATION_HOURS=24

# ─── 应用密钥 ───────────────────────────────────────────────────────────────
# 生成强随机密钥示例：openssl rand -hex 32
APP_SECRET=<generate-a-strong-secret-min-32-chars>

# ─── CORS 允许的来源 ────────────────────────────────────────────────────────
# 多个来源用逗号分隔
CORS_ALLOWED_ORIGINS=http://10.10.8.84:3000

# ─── 服务器配置 ─────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=release

# ─── 前端构建变量（docker build 时通过 --build-arg 注入或提前写入前端 .env.production）
# 此处仅记录，前端 Vite 变量通常在构建阶段固化
VITE_API_BASE_URL=http://10.10.8.84:8080

# AI-HMS 生产环境配置模板
# 复制本文件为 .env 后填入真实值，严禁提交真实密钥/密码。

## 数据库（老血透库）
DB_HOST=<REQUIRED: LEGACY_DB_HOST>
DB_PORT=<REQUIRED: LEGACY_DB_PORT>
DB_USER=<REQUIRED: LEGACY_DB_USER>
DB_PASSWORD=<REQUIRED: LEGACY_DB_PASSWORD>
DB_NAME=<REQUIRED: LEGACY_DB_NAME>
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

## JWT / 应用密钥
# 生成示例：openssl rand -hex 32
JWT_SECRET=<REQUIRED: JWT_SECRET>
JWT_EXPIRATION_HOURS=24
APP_SECRET=<REQUIRED: APP_SECRET>

## CORS
# 多个来源使用英文逗号分隔
CORS_ALLOWED_ORIGINS=<REQUIRED: CORS_ALLOWED_ORIGINS>

## 服务器
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=release
LOG_REQUESTS=false
LOG_SQL_MODE=silent
LOG_SLOW_SQL_MS=1000

## 紧急认证（默认关闭，生产环境建议保持 false）
# false: 禁用所有紧急认证入口（内置管理员 + DEFAULT_PASSWORD 回退）
# true : 启用紧急认证入口，仅用于受控排障，恢复正常后立即关闭
AUTH_EMERGENCY_ENABLED=false

# 启用紧急认证后，内置管理员账号默认回退为：
#   用户名 hms_admin
#   密码   Hms@Admin2024
# 建议在启用时显式覆盖，避免依赖代码内默认值。
# BUILTIN_ADMIN_USER=<EMERGENCY_ADMIN_USERNAME>
# BUILTIN_ADMIN_PASS=<EMERGENCY_ADMIN_PASSWORD>

# 启用紧急认证后，如未显式配置 DEFAULT_PASSWORD，将回退到代码内默认应急口令。
# 强烈建议仅在短时排障时显式设置，并在排障完成后立即移除。
# DEFAULT_PASSWORD=<EMERGENCY_SHARED_PASSWORD>

## 前端构建变量（由前端构建阶段注入）
# VITE_API_BASE_URL=https://your-api-host
